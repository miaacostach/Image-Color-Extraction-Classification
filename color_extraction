            'Model': 'GMM',
            'Cluster': i,
            'R': c[0], 'G': c[1], 'B': c[2],
            'Proportion': cnt / total_pixels
        })

  
# Convert the list of results to a DataFrame
results_df = pd.DataFrame(results_list)

