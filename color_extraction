# ✅ IMPORTACIÓN DE LIBRERÍAS
import cv2
import numpy as np
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans, MeanShift, estimate_bandwidth
from sklearn.mixture import GaussianMixture
from plantcv import plantcv as pcv
import pandas as pd
import os

# ✅ CARGAR Y CONFIGURAR PlantCV
pcv.params.debug = None
pcv.params.debug_outdir = "/content/sample_data/"  # Para guardar outputs si se quiere

# ✅ RUTA DE IMÁGENES
image_paths = ['/content/sample_data/G20387_2.png',
               '/content/sample_data/G4520_1.png']

# ✅ FUNCIÓN: segmentar imagen con PlantCV (colores preservados)
def segment_with_plantcv(path):
    # Leer imagen original en RGB
    rgb_img, _, _ = pcv.readimage(path)

    # Convertir a escala de grises usando el canal 'a' de LAB
    gray_img = pcv.rgb2gray_lab(rgb_img=rgb_img, channel='a')

    # Umbral binario
    thresh = pcv.threshold.binary(gray_img=gray_img, threshold=120, object_type='light')

    # Rellenar huecos pequeños
    filled = pcv.fill(bin_img=thresh, size=200)

    # Crear máscara booleana
    mask_bool = filled.astype(bool)

    # Aplicar máscara: copiar solo los píxeles originales donde la máscara es True
    masked = np.zeros_like(rgb_img)
    masked[mask_bool] = rgb_img[mask_bool]

    # Extraer píxeles segmentados (no negros)
    pixels = rgb_img[mask_bool]  # Usa directamente la imagen original

    return masked, pixels


# ✅ FUNCIÓN: mostrar colores extraídos
def plot_colors(colors, counts, title):
    fig, ax = plt.subplots(1, figsize=(6, 1))
    start = 0
    total = sum(counts)
    for color, count in zip(colors, counts):
        end = start + count / total
        ax.fill_between([start, end], 0, 1, color=np.array(color)/255)
        start = end
    ax.set_xticks([])
    ax.set_yticks([])
    ax.set_title(title)
    plt.show()

# ✅ FUNCIONES PARA CLUSTERING
def extract_kmeans(pixels, k=4):
    kmeans = KMeans(n_clusters=k, n_init=10)
    labels = kmeans.fit_predict(pixels)
    centers = kmeans.cluster_centers_.astype(int)
    counts = np.bincount(labels)
    return centers, counts

def extract_gmm(pixels, k=4):
    gmm = GaussianMixture(n_components=k)
    labels = gmm.fit_predict(pixels)
    centers = gmm.means_.astype(int)
    counts = np.bincount(labels)
    return centers, counts


# ✅ DATAFRAME FINAL PARA GUARDAR RESULTADOS
results_list = []

# ✅ PROCESAR CADA IMAGEN
for path in image_paths:
    img_name = os.path.basename(path)
    print(f"🔍 Procesando: {img_name}")

    # Segmentar con PlantCV
    segmented, pixels = segment_with_plantcv(path)

    # Mostrar imagen segmentada
    plt.imshow(segmented)
    plt.axis("off")
    plt.title("Segmentación PlantCV")
    plt.show()

    total_pixels = len(pixels)

    # 🔸 K-Means
    km_colors, km_counts = extract_kmeans(pixels, k=3)
    plot_colors(km_colors, km_counts, "🎯 K-Means Colors")
    for i, (c, cnt) in enumerate(zip(km_colors, km_counts)):
        results_list.append({
            'Image': img_name,
            'Model': 'KMeans',
            'Cluster': i,
            'R': c[0], 'G': c[1], 'B': c[2],
